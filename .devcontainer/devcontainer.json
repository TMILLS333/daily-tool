{
  // Daily Tool — GitHub Codespaces config (in-room hands-on environment).
  // Lets a designer with no local setup boot the app in the browser and reach
  // it at a shareable URL. Full attendee walkthrough: ../CODESPACES.md
  "name": "Daily Tool",

  // Node 20 toolchain, the version Next 16 targets. TypeScript image so tsc and
  // the editor work out of the box.
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",

  // Install dependencies. This runs DURING a prebuild, so a prebuilt codespace
  // already has node_modules and a fresh account boots fast. Keep heavy install
  // work here (onCreate), not in postCreate, or the prebuild will not cache it.
  "onCreateCommand": "npm install",

  // The app's dev port. forwardPorts surfaces it immediately regardless of the
  // dev server's bind address. The attendee sets it to Public from the Ports
  // panel to get a shareable live URL (see CODESPACES.md).
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Daily Tool",
      "onAutoForward": "notify"
    }
  },

  // Start the app whenever the codespace is (re)attached, so it boots straight
  // to a running tool with no terminal step. To stop and restart it, use the
  // documented `npm run dev`.
  "postAttachCommand": "npm run dev"
}
