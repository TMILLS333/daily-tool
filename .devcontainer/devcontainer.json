{
  // GenUI Studio — GitHub Codespaces config (in-room hands-on environment).
  // Lets a designer with no local setup boot the app in the browser and reach
  // it at a shareable URL. Full attendee walkthrough: ../CODESPACES.md
  "name": "GenUI Studio",

  // Non-secret gateway ids, injected into every Codespace so attendees only
  // need to paste the ONE shared gateway token (CF_AIG_TOKEN) into .env. The
  // token is handed out at the event and is never committed. Account id and
  // gateway name are public identifiers, not credentials. See ../CODESPACES.md.
  "containerEnv": {
    "CF_ACCOUNT_ID": "29c15842e0b9cdef36442ac3318f5745",
    "CF_AIG_GATEWAY_ID": "genui-workshop"
  },

  // Node 20 toolchain, the version Next 16 targets. TypeScript image so tsc and
  // the editor work out of the box.
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",

  // Install dependencies and build the production bundle. Both run DURING a
  // prebuild, so a prebuilt codespace already has node_modules + .next and a
  // fresh account boots fast. Keep heavy work here (onCreate), not in
  // postCreate, or the prebuild will not cache it. We build here because
  // `next start` needs .next to exist, and we run the production server (not
  // `next dev`) because the Turbopack dev runtime breaks the agent run with a
  // browser fetch "Illegal invocation" error.
  "onCreateCommand": "npm install && npm run build",

  // The app's dev port. forwardPorts surfaces it immediately regardless of the
  // dev server's bind address. The attendee sets it to Public from the Ports
  // panel to get a shareable live URL (see CODESPACES.md).
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "GenUI Studio",
      "onAutoForward": "notify"
    }
  },

  // Do NOT auto-start the server. A fresh Codespace has no .env yet, so an
  // auto-started app boots keyless and errors, which confused attendees. Instead
  // we print the setup steps and let them start it once their key is in. (`next
  // start` reads .env only at boot, and the production server is deliberate: the
  // Turbopack dev runtime `next dev` breaks the agent run in the browser.)
  "postAttachCommand": "echo '' && echo 'NEXT STEPS: 1) cp .env.example .env   2) add your AI key in .env (see CODESPACES.md)   3) npm run start' && echo ''"
}
