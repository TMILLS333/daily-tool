# Cloudflare secrets — the Worker equivalent of .env.
#
# Two uses:
#  - LOCAL Worker preview: copy this file to `.dev.vars` and fill the values you
#    need, then run `npm run preview`.
#  - LIVE deploy: you do NOT edit this file. The Deploy-to-Cloudflare button
#    reads these field names and prompts you for each value in the dashboard,
#    storing them as encrypted Cloudflare Secrets on your own Worker. They are
#    never committed and never sent to the browser.

# --- Gemini path (deployed default) ---
GOOGLE_API_KEY=

# --- Workers-AI (scout) path ---
# Fill these two, then set MODEL=@cf/meta/llama-4-scout-17b-16e-instruct
# (MODEL lives in wrangler.jsonc vars, or override it as a deploy variable).
CF_ACCOUNT_ID=
CF_API_TOKEN=
