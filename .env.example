# ── Daily Tool: which AI runs your app ─────────────────────────────────
#
# DEFAULT (workshop): bring your own free Google Gemini key. It's free, no card,
# about a minute to make.
#
#   1. Get a key: https://aistudio.google.com/apikey  ->  Create API key
#   2. Paste it after GOOGLE_API_KEY= below  (no spaces, no quotes)
#   3. Save, then start the app.
#
# Your key stays server-side, never sent to the browser, and is never committed
# (the repo ignores `.env`).

GOOGLE_API_KEY=

# ── Or use the shared workshop token (backup) ──────────────────────────
#
# Don't want to make a key? Your host can hand out ONE token for the shared,
# funded Claude gateway at the event. Paste it after CF_AIG_TOKEN= instead — the
# account + gateway ids are already set for you inside the Codespace.
# CF_AIG_TOKEN=
#
# Running locally instead of in a Codespace? Uncomment these two non-secret ids
# so the app can find the gateway (Codespaces set them for you automatically):
# CF_ACCOUNT_ID=29c15842e0b9cdef36442ac3318f5745
# CF_AIG_GATEWAY_ID=genui-workshop

# ── Other providers? (optional) ────────────────────────────────────────
#
# Bring ANY ONE key instead and it OVERRIDES the shared gateway (you pay that
# provider; your key stays server-side). If you set more than one, the order is
# Anthropic > OpenAI > Google, and any personal key beats the gateway token.
#   Anthropic:  https://console.anthropic.com -> API keys
#   OpenAI:     https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: pin a model. Personal-key defaults are gemini-2.5-flash /
# claude-sonnet-4-6 / gpt-4.1-mini. The gateway default is anthropic/claude-sonnet-4-6.
# Gateway model ids use the {provider}/{model} form (e.g. openai/gpt-4.1-mini,
# google-ai-studio/gemini-2.5-flash, anthropic/claude-sonnet-4-6).
# MODEL=google/gemini-2.5-flash
# CF_AIG_MODEL=anthropic/claude-sonnet-4-6

# CopilotKit sends anonymous usage telemetry by default. Uncomment to opt out.
# COPILOTKIT_TELEMETRY_DISABLED=true

# ── Deploying live to Cloudflare? ──────────────────────────────────────
#
# This .env file is for running the app in a Codespace or on your own machine.
# To put the app live on the web, you do NOT use this file. The
# Deploy-to-Cloudflare button (see the README) handles keys as encrypted
# Cloudflare Secrets. The secret field names live in `.dev.vars.example`.
