# ── Daily Tool: which AI runs your app ─────────────────────────────────
#
# DEFAULT (workshop): the shared Claude gateway. You do NOT need your own AI
# key. Your host gives you ONE token at the event — that's all you add.
#
#   1. Duplicate this file as `.env`  (right-click -> Copy, Paste, rename to .env)
#   2. Paste the event token after CF_AIG_TOKEN=  (no spaces, no quotes)
#   3. Save, then start the app.
#
# The account + gateway ids are already set for you inside the Codespace, so the
# token is the only thing you add. Your token stays server-side, never sent to
# the browser, and is never committed (the repo ignores `.env`).

CF_AIG_TOKEN=

# Running locally instead of in a Codespace? Uncomment these two non-secret ids
# so the app can find the gateway (Codespaces set them for you automatically):
# CF_ACCOUNT_ID=29c15842e0b9cdef36442ac3318f5745
# CF_AIG_GATEWAY_ID=genui-workshop

# ── Prefer your own key? (optional) ────────────────────────────────────
#
# Bring ANY ONE of these instead and it OVERRIDES the shared gateway (you pay
# that provider; your key stays server-side). Clear it again to return to the
# gateway. If you set more than one, the order is Anthropic > OpenAI > Google.
#   Google (free, no card):  https://aistudio.google.com   -> API keys
#   Anthropic:               https://console.anthropic.com -> API keys
#   OpenAI:                  https://platform.openai.com/api-keys
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: pin a model. The gateway default is anthropic/claude-sonnet-4-6.
# Personal-key defaults are gemini-2.5-flash / claude-haiku-4-5 / gpt-4.1-mini.
# Gateway model ids use the {provider}/{model} form (e.g. openai/gpt-4.1-mini,
# google-ai-studio/gemini-2.5-flash, anthropic/claude-haiku-4-5).
# CF_AIG_MODEL=anthropic/claude-sonnet-4-6
# MODEL=google/gemini-2.5-flash

# CopilotKit sends anonymous usage telemetry by default. Uncomment to opt out.
# COPILOTKIT_TELEMETRY_DISABLED=true

# ── Deploying live to Cloudflare? ──────────────────────────────────────
#
# This .env file is for running the app in a Codespace or on your own machine.
# To put the app live on the web, you do NOT use this file. The
# Deploy-to-Cloudflare button (see the README) handles keys as encrypted
# Cloudflare Secrets. The secret field names live in `.dev.vars.example`.
